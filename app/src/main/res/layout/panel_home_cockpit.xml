<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/panelHome"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="12dp"
    android:paddingEnd="14dp"
    android:paddingBottom="96dp">

    <!-- Adapter Flashcard — rich connection status with transport icon, signal bars, voltage -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="16dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingTop="12dp"
            android:paddingEnd="14dp"
            android:paddingBottom="12dp">

            <!-- Transport icon with rounded background -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp">

                <View
                    android:id="@+id/cockpitAdapterIconBg"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_adapter_icon" />

                <ImageView
                    android:id="@+id/cockpitAdapterIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_auto"
                    android:contentDescription="Adapter type" />
            </FrameLayout>

            <!-- Center: adapter name, status, health -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/cockpitConnection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_status_disconnected"
                    android:textColor="@color/muted"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/cockpitAdapter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="@string/home_status_connect_desc"
                    android:textColor="@color/muted"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/cockpitConnectionHealth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:maxLines="1"
                    android:text="Connection diagnostics ready"
                    android:textColor="@color/muted"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Right: signal bars, voltage, protocol badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

                <!-- Signal quality bars (4 bars, toggled in code) -->
                <LinearLayout
                    android:id="@+id/cockpitSignalBars"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:gravity="bottom|end"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <View
                        android:id="@+id/signalBar1"
                        android:layout_width="3dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="2dp"
                        android:background="#39D98A" />

                    <View
                        android:id="@+id/signalBar2"
                        android:layout_width="3dp"
                        android:layout_height="8dp"
                        android:layout_marginEnd="2dp"
                        android:background="#39D98A" />

                    <View
                        android:id="@+id/signalBar3"
                        android:layout_width="3dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="2dp"
                        android:background="#39D98A" />

                    <View
                        android:id="@+id/signalBar4"
                        android:layout_width="3dp"
                        android:layout_height="12dp"
                        android:background="#39D98A" />
                </LinearLayout>

                <!-- Voltage mini-readout -->
                <TextView
                    android:id="@+id/cockpitAdapterVoltage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="--.- V"
                    android:textColor="@color/accent"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:visibility="gone" />

                <!-- Protocol badge -->
                <TextView
                    android:id="@+id/cockpitProtocol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_status_chip"
                    android:gravity="center"
                    android:minHeight="28dp"
                    android:paddingStart="10dp"
                    android:paddingTop="3dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="3dp"
                    android:text="@string/home_status_obd2"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="20dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.08"
                android:text="@string/home_title_live_telemetry"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/cockpitRpm" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="monospace" android:text="---" android:textColor="@color/text" android:textSize="44sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_label_rpm" android:textColor="@color/muted" android:textSize="11sp" android:textStyle="bold" />
                </LinearLayout>
                <View android:layout_width="1dp" android:layout_height="72dp" android:background="@color/border" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/cockpitSpeed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="monospace" android:text="---" android:textColor="@color/primary" android:textSize="34sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_label_kmh" android:textColor="@color/muted" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/home_title_live_data_graph" android:textColor="@color/text" android:textSize="12sp" android:textStyle="bold" />
                <TextView android:id="@+id/cockpitGraphLive" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_label_live" android:textColor="@color/accent" android:textSize="10sp" android:textStyle="bold" />
                <TextView android:id="@+id/cockpitGraphPause" android:layout_width="32dp" android:layout_height="32dp" android:layout_marginStart="6dp" android:gravity="center" android:text="Ⅱ" android:textColor="@color/text" android:textSize="15sp" android:textStyle="bold" android:background="?attr/selectableItemBackgroundBorderless" android:clickable="true" android:focusable="true" android:contentDescription="Pause live graph" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/home_label_rolling_window" android:textColor="@color/muted" android:textSize="9sp" />
                <TextView android:id="@+id/cockpitGraphRange" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_status_chip" android:paddingStart="10dp" android:paddingTop="4dp" android:paddingEnd="10dp" android:paddingBottom="4dp" android:text="60s" android:textColor="@color/primary" android:textSize="10sp" android:textStyle="bold" />
            </LinearLayout>
            <com.alpha.obd2logger.LiveMultiGraphView
                android:id="@+id/cockpitLiveGraph"
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:layout_marginTop="4dp"
                android:contentDescription="Live RPM, speed, and boost graph" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:layout_marginTop="4dp">
                <TextView android:id="@+id/cockpitLegendRpm" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/home_label_rpm_legend" android:textColor="#29A8FF" android:textSize="9sp" android:clickable="true" android:focusable="true" android:contentDescription="@string/home_toggle_rpm_graph" />
                <TextView android:id="@+id/cockpitLegendSpeed" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/home_label_speed_legend" android:textColor="#39D98A" android:textSize="9sp" android:clickable="true" android:focusable="true" android:contentDescription="@string/home_toggle_speed_graph" />
                <TextView android:id="@+id/cockpitLegendBoost" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/home_label_boost_legend" android:textColor="#A855F7" android:textSize="9sp" android:clickable="true" android:focusable="true" android:contentDescription="@string/home_toggle_boost_graph" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/cockpitCoolant" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="@color/warning" android:textSize="24sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_label_coolant" android:textColor="@color/muted" android:textSize="9sp" android:textStyle="bold" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/cockpitVoltage" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="@color/accent" android:textSize="24sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_label_voltage" android:textColor="@color/muted" android:textSize="9sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="12dp" android:layout_marginBottom="10dp" android:background="@color/border" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="58dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/panel" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/cockpitBoost" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="@color/primary" android:textSize="19sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_label_boost_psi" android:textColor="@color/muted" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="58dp" android:layout_weight="1" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:background="@drawable/panel" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/cockpitThrottle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="@color/accent" android:textSize="19sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_label_throttle_pct" android:textColor="@color/muted" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="58dp" android:layout_weight="1" android:layout_marginStart="4dp" android:background="@drawable/panel" android:gravity="center" android:orientation="vertical">
                    <TextView android:id="@+id/cockpitFuelTrim" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="#A78BFA" android:textSize="19sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/home_label_fuel_trim_pct" android:textColor="@color/muted" android:textSize="8sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cockpitInsightCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="16dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_speed"
                app:tint="@color/primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.06"
                    android:text="@string/home_title_ai_insight"
                    android:textColor="@color/primary"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/cockpitInsightTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/home_ai_insight_collecting"
                    android:textColor="@color/text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/cockpitInsightMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:maxLines="2"
                    android:text="@string/home_ai_insight_collecting_detail"
                    android:textColor="@color/muted"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/cockpitInsightMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="@string/home_ai_insight_local"
                    android:textColor="@color/muted"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cockpitDiagnostics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="10dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="16dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">
            <ImageView
                android:id="@+id/cockpitDiagnosticIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_build"
                app:tint="@color/accent" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_title_diagnostic_health"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/cockpitDiagnosticSummary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/home_diagnostic_no_codes"
                    android:textColor="@color/accent"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/cockpitDiagnosticMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/home_diagnostic_ready_scan"
                    android:textColor="@color/muted"
                    android:textSize="10sp" />
            </LinearLayout>
            <TextView
                android:id="@+id/cockpitDiagnosticChevron"
                android:layout_width="32dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="›"
                android:textColor="@color/muted"
                android:textSize="26sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="10dp"
        android:letterSpacing="0.08"
        android:text="@string/home_title_quick_access"
        android:textColor="@color/muted"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Detailed 3-column cards, matching the supplied reference. -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
        <com.google.android.material.card.MaterialCardView android:id="@+id/cockpitGauges" android:layout_width="0dp" android:layout_height="160dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" app:cardBackgroundColor="?attr/colorSurface" app:cardCornerRadius="16dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:orientation="vertical"><ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_speed" app:tint="@color/primary" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:text="@string/home_card_gauges_title" android:textColor="@color/text" android:textSize="11sp" android:textStyle="bold" android:maxLines="2" android:ellipsize="end" /><TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="3dp" android:text="@string/home_card_gauges_desc" android:textColor="@color/muted" android:textSize="10sp" android:maxLines="3" android:ellipsize="end" /><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="end" android:text="›" android:textColor="@color/muted" android:textSize="22sp" /></LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:id="@+id/cockpitLogs" android:layout_width="0dp" android:layout_height="160dp" android:layout_weight="1" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" app:cardBackgroundColor="?attr/colorSurface" app:cardCornerRadius="16dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:orientation="vertical"><ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_list" app:tint="@color/primary" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:text="@string/home_card_logs_title" android:textColor="@color/text" android:textSize="11sp" android:textStyle="bold" android:maxLines="2" android:ellipsize="end" /><TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="3dp" android:text="@string/home_card_logs_desc" android:textColor="@color/muted" android:textSize="10sp" android:maxLines="3" android:ellipsize="end" /><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="end" android:text="›" android:textColor="@color/muted" android:textSize="22sp" /></LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:id="@+id/cockpitDashboard" android:layout_width="0dp" android:layout_height="160dp" android:layout_weight="1" android:layout_marginStart="4dp" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" app:cardBackgroundColor="?attr/colorSurface" app:cardCornerRadius="16dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp" android:orientation="vertical"><ImageView android:layout_width="28dp" android:layout_height="28dp" android:src="@drawable/ic_dashboard" app:tint="@color/primary" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:text="@string/home_card_dashboard_title" android:textColor="@color/text" android:textSize="11sp" android:textStyle="bold" android:maxLines="2" android:ellipsize="end" /><TextView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="3dp" android:text="@string/home_card_dashboard_desc" android:textColor="@color/muted" android:textSize="10sp" android:maxLines="3" android:ellipsize="end" /><TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="end" android:text="›" android:textColor="@color/muted" android:textSize="22sp" /></LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <com.google.android.material.card.MaterialCardView android:id="@+id/cockpitMap" android:layout_width="0dp" android:layout_height="160dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" app:cardBackgroundColor="?attr/colorSurface" app:cardCornerRadius="16dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp">
