<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/panelHome"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/panel"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">
            <View android:id="@+id/cockpitStatusDot" android:layout_width="10dp" android:layout_height="10dp" android:background="@drawable/bg_status_dot_off" android:layout_marginEnd="10dp" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                <TextView android:id="@+id/cockpitConnection" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DISCONNECTED" android:textColor="@color/muted" android:textSize="13sp" android:textStyle="bold" />
                <TextView android:id="@+id/cockpitAdapter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Select an OBD2 adapter" android:textColor="@color/muted" android:textSize="11sp" android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCockpitConnect"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:contentDescription="Connect"
            app:backgroundTint="@color/primary"
            app:cornerRadius="24dp"
            app:icon="@android:drawable/ic_media_play"
            app:iconTint="@color/background" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="14dp"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="24dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="LIVE DASHBOARD" android:textColor="@color/primary" android:textSize="12sp" android:textStyle="bold" android:letterSpacing="0.08" />
                <TextView android:id="@+id/cockpitProtocol" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OBD2" android:textColor="@color/muted" android:textSize="11sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="16dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/cockpitRpm" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="@color/text" android:textSize="48sp" android:textStyle="bold" android:fontFamily="monospace" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RPM" android:textColor="@color/muted" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>
                <View android:layout_width="1dp" android:layout_height="82dp" android:background="@color/border" />
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:id="@+id/cockpitSpeed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="@color/primary" android:textSize="34sp" android:textStyle="bold" android:fontFamily="monospace" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="km/h" android:textColor="@color/muted" android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
            <com.alpha.obd2logger.GraphView android:id="@+id/cockpitRpmTrend" android:layout_width="match_parent" android:layout_height="104dp" android:layout_marginTop="12dp" android:contentDescription="Live RPM graph" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
        <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1" android:layout_marginEnd="5dp" app:cardBackgroundColor="?attr/colorSurface" app:cardCornerRadius="20dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical"><TextView android:id="@+id/cockpitCoolant" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="@color/warning" android:textSize="28sp" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="COOLANT °C" android:textColor="@color/muted" android:textSize="10sp" android:textStyle="bold" /></LinearLayout></com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="100dp" android:layout_weight="1" android:layout_marginStart="5dp" app:cardBackgroundColor="?attr/colorSurface" app:cardCornerRadius="20dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:orientation="vertical"><TextView android:id="@+id/cockpitVoltage" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="---" android:textColor="@color/accent" android:textSize="28sp" android:textStyle="bold" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VOLTAGE · V" android:textColor="@color/muted" android:textSize="10sp" android:textStyle="bold" /></LinearLayout></com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="QUICK ACCESS" android:textColor="@color/muted" android:textSize="12sp" android:textStyle="bold" android:letterSpacing="0.08" android:layout_marginTop="10dp" android:layout_marginBottom="10dp" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
        <com.google.android.material.card.MaterialCardView android:id="@+id/cockpitGauges" android:layout_width="0dp" android:layout_height="96dp" android:layout_weight="1" android:layout_marginEnd="5dp" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" app:cardBackgroundColor="?attr/colorSurface" app:cardCornerRadius="20dp" app:strokeColor="@color/primary" app:strokeWidth="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="14dp" android:orientation="vertical"><ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_speed" app:tint="@color/primary" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GAUGES" android:textColor="@color/text" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="8dp" /></LinearLayout></com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:id="@+id/cockpitDashboard" android:layout_width="0dp" android:layout_height="96dp" android:layout_weight="1" android:layout_marginStart="5dp" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" app:cardBackgroundColor="?attr/colorSurface" app:cardCornerRadius="20dp" app:strokeColor="@color/primary" app:strokeWidth="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="14dp" android:orientation="vertical"><ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_dashboard" app:tint="@color/primary" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TABLE" android:textColor="@color/text" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="8dp" /></LinearLayout></com.google.android.material.card.MaterialCardView>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
        <com.google.android.material.card.MaterialCardView android:id="@+id/cockpitMap" android:layout_width="0dp" android:layout_height="96dp" android:layout_weight="1" android:layout_marginEnd="5dp" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" app:cardBackgroundColor="?attr/colorSurface" app:cardCornerRadius="20dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="14dp" android:orientation="vertical"><ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_map" app:tint="@color/primary" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TRIM MAP" android:textColor="@color/text" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="8dp" /></LinearLayout></com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:id="@+id/cockpitDtc" android:layout_width="0dp" android:layout_height="96dp" android:layout_weight="1" android:layout_marginStart="5dp" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" app:cardBackgroundColor="?attr/colorSurface" app:cardCornerRadius="20dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="14dp" android:orientation="vertical"><ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_build" app:tint="@color/warning" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DTC SCANNER" android:textColor="@color/text" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="8dp" /></LinearLayout></com.google.android.material.card.MaterialCardView>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="16dp">
        <com.google.android.material.card.MaterialCardView android:id="@+id/cockpitLogs" android:layout_width="0dp" android:layout_height="96dp" android:layout_weight="1" android:layout_marginEnd="5dp" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" app:cardBackgroundColor="?attr/colorSurface" app:cardCornerRadius="20dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="14dp" android:orientation="vertical"><ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_list" app:tint="@color/primary" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LIVE LOGS" android:textColor="@color/text" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="8dp" /></LinearLayout></com.google.android.material.card.MaterialCardView>
        <com.google.android.material.card.MaterialCardView android:id="@+id/cockpitBattery" android:layout_width="0dp" android:layout_height="96dp" android:layout_weight="1" android:layout_marginStart="5dp" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" app:cardBackgroundColor="?attr/colorSurface" app:cardCornerRadius="20dp" app:strokeColor="?attr/colorOutlineVariant" app:strokeWidth="1dp"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="14dp" android:orientation="vertical"><ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@drawable/ic_battery" app:tint="@color/accent" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="POWER" android:textColor="@color/text" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="8dp" /></LinearLayout></com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</LinearLayout>
