<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Bottom Sheet Drag Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@color/border" />

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/how_to_read_map_title"
            android:textColor="@color/text"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- What the values actually represent -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="12dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="@string/how_to_read_map_desc"
                android:textColor="@color/text"
                android:textSize="12sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- VE map: what it means and how to read the three views -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/how_to_read_ve_map_title"
            android:textColor="@color/text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="12dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="@string/how_to_read_ve_map_desc"
                android:textColor="@color/text"
                android:textSize="12sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Color Legend Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/map_info_color_legend_header"
            android:textColor="@color/muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="@string/map_info_color_context"
            android:textColor="@color/muted"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="?attr/colorSurfaceVariant"
            android:padding="12dp"
            android:layout_marginBottom="20dp">

            <!-- Perfect -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#22C55E"
                    app:strokeWidth="0dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="12dp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/map_info_legend_perfect"
                    android:textColor="@color/text"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Negative -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#EAB308"
                    app:strokeWidth="0dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="12dp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/map_info_legend_slightly_rich"
                    android:textColor="@color/text"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Strongly negative -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#EF4444"
                    app:strokeWidth="0dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="12dp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/map_info_legend_very_rich"
                    android:textColor="@color/text"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Positive -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#06B6D4"
                    app:strokeWidth="0dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="12dp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/map_info_legend_slightly_lean"
                    android:textColor="@color/text"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Strongly positive -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#3B82F6"
                    app:strokeWidth="0dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="12dp" />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/map_info_legend_very_lean"
                    android:textColor="@color/text"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Calculation Logic Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/map_info_tuning_logic_header"
            android:textColor="@color/muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="12dp" />

        <!-- Petrol Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:cardBackgroundColor="?attr/colorSurface">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/map_info_petrol_title"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/map_info_trim_formula"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:layout_marginTop="2dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/map_info_petrol_desc"
                    android:textColor="@color/muted"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- LPG Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:cardBackgroundColor="?attr/colorSurface">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/map_info_lpg_title"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/map_info_trim_formula"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:layout_marginTop="2dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/map_info_lpg_desc"
                    android:textColor="@color/muted"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Deviation Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:cardBackgroundColor="?attr/colorSurface">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/map_info_deviation_title"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/map_info_delta_formula"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:layout_marginTop="2dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/map_info_deviation_desc"
                    android:textColor="@color/muted"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Tune Assist Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:cardBackgroundColor="?attr/colorSurface">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/map_info_tune_assist_title"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/map_info_tune_formula"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:layout_marginTop="2dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/map_info_tune_assist_desc"
                    android:textColor="@color/muted"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Worked examples -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/map_info_examples_header"
            android:textColor="@color/muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="12dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="@string/map_info_examples_desc"
                android:textColor="@color/text"
                android:textSize="12sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Data quality -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/map_info_quality_header"
            android:textColor="@color/muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="12dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="@string/map_info_quality_desc"
                android:textColor="@color/text"
                android:textSize="12sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Diesel applicability -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/map_info_diesel_header"
            android:textColor="@color/muted"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="12dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="@string/map_info_diesel_desc"
                android:textColor="@color/text"
                android:textSize="12sp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Note Text -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/map_info_note"
            android:textColor="@color/muted"
            android:textSize="11sp"
            android:textStyle="italic"
            android:layout_marginBottom="24dp" />

        <!-- Close Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMapInfoClose"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="@string/map_info_close"
            style="@style/Widget.Material3.Button"
            android:layout_marginBottom="12dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
