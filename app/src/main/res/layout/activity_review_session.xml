<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/reviewHeader"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/text"
                android:contentDescription="Back" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/btnBack"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/reviewFileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/reviewStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parsing data..."
                    android:textColor="@color/muted"
                    android:textSize="12sp" />
            </LinearLayout>
        </RelativeLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/reviewProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-4dp"
        android:indeterminate="true"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/reviewHeader" />

    <!-- Content area -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/reviewProgress"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/reviewMapToggle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:checkedButton="@+id/btnReviewPetrol"
                app:cornerRadius="2dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReviewPetrol"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="@string/petrol"
                    android:textSize="11sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:maxLines="1"
                    style="?attr/materialButtonOutlinedStyle" />
                    
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReviewLpg"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="@string/lpg"
                    android:textSize="11sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:maxLines="1"
                    style="?attr/materialButtonOutlinedStyle" />
                    
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReviewDiff"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="@string/deviation"
                    android:textSize="11sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:maxLines="1"
                    style="?attr/materialButtonOutlinedStyle" />
                    
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReviewCorrection"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="@string/tune_assist"
                    android:textSize="11sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    android:maxLines="1"
                    style="?attr/materialButtonOutlinedStyle" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/map_axes"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="400dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <com.alpha.obd2logger.FuelMapView
                    android:id="@+id/reviewFuelMapView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- Learned VE surface replayed from ve_map_* columns (≥3.33 logs).
                 Hidden when the log predates the feature. Tap cycles
                 Petrol VE / LPG VE / ΔVE. -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/reviewVeMapCard"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <com.alpha.obd2logger.VeMapView
                    android:id="@+id/reviewVeMapView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- GPS route replay: hidden unless the log carries gps_* columns -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/reviewRouteCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/review_route_title"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/reviewRouteToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        app:checkedButton="@id/btnRouteSpeed">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRouteSpeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/review_route_speed"
                            android:textSize="11sp"
                            style="?attr/materialButtonOutlinedStyle" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRouteBoost"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/review_route_boost"
                            android:textSize="11sp"
                            style="?attr/materialButtonOutlinedStyle" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <com.alpha.obd2logger.RouteMapView
                        android:id="@+id/reviewRouteMapView"
                        android:layout_width="match_parent"
                        android:layout_height="280dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Professional Formula & Description Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/map_formula_logic_title"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/map_formula_delta_title"
                        android:textColor="@color/primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@color/background"
                        android:padding="10dp"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/map_formula_hint"
                        android:textColor="@color/text"
                        android:textSize="13sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Professional Color Legend Grid -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/map_color_legend_title"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:alignmentMode="alignBounds"
                        android:columnOrderPreserved="false">

                        <!-- Perfect (Green) -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_margin="4dp">
                            <View
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:background="#22C55E"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/map_legend_perfect"
                                android:textColor="@color/text"
                                android:textSize="12sp"/>
                        </LinearLayout>

                        <!-- Slightly Rich (Yellow) -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_margin="4dp">
                            <View
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:background="#EAB308"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/map_legend_slightly_rich"
                                android:textColor="@color/text"
                                android:textSize="12sp"/>
                        </LinearLayout>

                        <!-- Slightly Lean (Light Blue) -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_margin="4dp">
                            <View
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:background="#06B6D4"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/map_legend_slightly_lean"
                                android:textColor="@color/text"
                                android:textSize="12sp"/>
                        </LinearLayout>

                        <!-- Very Rich (Red) -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_margin="4dp">
                            <View
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:background="#EF4444"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/map_legend_very_rich"
                                android:textColor="@color/text"
                                android:textSize="12sp"/>
                        </LinearLayout>

                        <!-- Very Lean (Dark Blue) -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_margin="4dp">
                            <View
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:background="#2563EB"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/map_legend_very_lean"
                                android:textColor="@color/text"
                                android:textSize="12sp"/>
                        </LinearLayout>

                    </GridLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReviewExportCsv"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="@string/export_tune_assist_csv"
                app:icon="@android:drawable/ic_menu_share"
                style="@style/Widget.Material3.Button.TonalButton"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReviewMapInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/how_to_read_map_title"
                app:icon="@android:drawable/ic_dialog_info"
                style="@style/Widget.Material3.Button.TextButton" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
