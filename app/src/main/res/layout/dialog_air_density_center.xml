<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Header Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_speed"
                app:tint="#38BDF8"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BANKS iDASH AIR DENSITY CENTER"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SAE J1349 Standard Correction &amp; Thermodynamics"
                    android:textColor="@color/muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnCloseAirDensityDialog"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="@color/text"
                android:contentDescription="Close" />
        </LinearLayout>

        <!-- Weather / Atmospheric Live Banner -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="14dp"
            app:strokeWidth="1dp"
            app:strokeColor="#38BDF8">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ATMOSPHERIC WEATHER &amp; SENSORS"
                        android:textColor="#38BDF8"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtDialogWeatherSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RH: --% • Temp: --°C • Baro: -- kPa"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDialogRefreshWeather"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="REFRESH"
                    android:textSize="11sp"
                    android:textColor="#38BDF8"
                    app:icon="@android:drawable/ic_popup_sync"
                    app:iconSize="14dp"
                    app:iconTint="#38BDF8" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Primary Air Density Pillars (AAD / MAD / BAD) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <!-- AAD Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="14dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#38BDF8">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AMBIENT (AAD)"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtDialogAAD"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#38BDF8"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="lbs/1000 ft³"
                        android:textColor="@color/muted"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/txtDialogAADPct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--% SAE J1349"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- MAD Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="14dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#10B981">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MANIFOLD (MAD)"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtDialogMAD"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#10B981"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="lbs/1000 ft³"
                        android:textColor="@color/muted"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/txtDialogMADPct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--% SAE J1349"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- BAD Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="14dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="#F59E0B">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BOOST (BAD)"
                        android:textColor="@color/muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtDialogBAD"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#F59E0B"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="lbs/1000 ft³"
                        android:textColor="@color/muted"
                        android:textSize="9sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Boost Added"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Section Title: SAE J1349 & Atmospheric Metrics -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAE J1349 &amp; ATMOSPHERIC CONDITIONS"
            android:textColor="?attr/colorOnSurface"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_dtc_card"
                android:padding="12dp"
                android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Density Altitude" android:textColor="@color/muted" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/txtDialogDensityAlt" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="-- ft" android:textColor="?attr/colorOnSurface" android:textSize="18sp" android:textStyle="bold" android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_dtc_card"
                android:padding="12dp"
                android:layout_marginStart="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SAE Correction CF" android:textColor="@color/muted" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/txtDialogSAECF" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textColor="?attr/colorOnSurface" android:textSize="18sp" android:textStyle="bold" android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_dtc_card"
                android:padding="12dp"
                android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Water Vapor Density" android:textColor="@color/muted" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/txtDialogGrains" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="-- grains" android:textColor="?attr/colorOnSurface" android:textSize="18sp" android:textStyle="bold" android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_dtc_card"
                android:padding="12dp"
                android:layout_marginStart="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Power Density (PDI)" android:textColor="@color/muted" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/txtDialogPDI" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--" android:textColor="?attr/colorOnSurface" android:textSize="18sp" android:textStyle="bold" android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <!-- Section Title: Thermodynamics & Turbo Efficiency -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TURBO &amp; INTERCOOLER THERMODYNAMICS"
            android:textColor="?attr/colorOnSurface"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_dtc_card"
                android:padding="12dp"
                android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Compressor Eff" android:textColor="@color/muted" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/txtDialogCompEff" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--%" android:textColor="#38BDF8" android:textSize="18sp" android:textStyle="bold" android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_dtc_card"
                android:padding="12dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Intercooler Eff" android:textColor="@color/muted" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/txtDialogICEff" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--%" android:textColor="#10B981" android:textSize="18sp" android:textStyle="bold" android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_dtc_card"
                android:padding="12dp"
                android:layout_marginStart="4dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Volumetric Eff" android:textColor="@color/muted" android:textSize="11sp" android:textStyle="bold" />
                <TextView android:id="@+id/txtDialogVE" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="--%" android:textColor="#F59E0B" android:textSize="18sp" android:textStyle="bold" android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <!-- Description Box -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardCornerRadius="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:text="Banks iDash Air Density Guide:\n• AAD measures oxygen availability in ambient air outside the car.\n• MAD measures density in your intake manifold after turbo and intercooler.\n• BAD shows density added above ambient pressure.\n• Higher AAD/MAD = More Oxygen = More Horsepower &amp; Optimal Combustion."
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:lineSpacingExtra="3dp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogCloseAirDensity"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="CLOSE"
            android:textColor="@color/background"
            android:textStyle="bold"
            app:backgroundTint="?attr/colorOnSurface"
            app:cornerRadius="14dp" />

    </LinearLayout>
</ScrollView>
