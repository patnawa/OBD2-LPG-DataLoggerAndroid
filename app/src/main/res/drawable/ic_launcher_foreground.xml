<?xml version="1.0" encoding="utf-8"?>
<!--
  Launcher glyph: a single machine-amber gauge on the gunmetal background.
  Geometry stays inside the adaptive-icon safe zone (r≈33 around 54,54):
  track outer edge is r≈29.5. One glyph, no clutter — it must read at 24 px.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Dial track: 245° steel arc, open at the bottom -->
    <path
        android:strokeColor="#3D444B"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M33.5,67 A26,26 0 1 1 74.5,67" />

    <!-- Amber sweep up to the needle position -->
    <path
        android:strokeColor="#FFB020"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M33.5,67 A26,26 0 0 1 68.9,32.7" />

    <!-- Tapered needle pointing at the sweep end -->
    <path
        android:fillColor="#FFB020"
        android:pathData="M51.5,52.3 L66,36.8 L56.5,55.7 Z" />

    <!-- Hub: amber ring with a dark center -->
    <path
        android:fillColor="#FFB020"
        android:pathData="M54,54m-5.5,0a5.5,5.5 0,1 1,11 0a5.5,5.5 0,1 1,-11 0" />
    <path
        android:fillColor="#14181B"
        android:pathData="M54,54m-2.2,0a2.2,2.2 0,1 1,4.4 0a2.2,2.2 0,1 1,-4.4 0" />

    <!-- Status LED in the dial's open mouth: green = running -->
    <path
        android:fillColor="#45D483"
        android:pathData="M54,70m-2.6,0a2.6,2.6 0,1 1,5.2 0a2.6,2.6 0,1 1,-5.2 0" />
</vector>
